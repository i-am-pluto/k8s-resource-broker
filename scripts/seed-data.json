[
  {
    "name": "k8s-efficient",
    "description": "Efficient resource profile — conservative CPU/memory for cost-sensitive workloads",
    "targets": [
      {
        "field": "/spec/containers/0/resources/requests",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "static",
          "config": {
            "value": {
              "cpu": "250m",
              "memory": "256Mi"
            }
          }
        }
      },
      {
        "field": "/spec/containers/0/resources/limits",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "static",
          "config": {
            "value": {
              "cpu": "500m",
              "memory": "512Mi"
            }
          }
        }
      }
    ],
    "selector": {
      "annotations": {
        "resource-broker/profile": "k8s-efficient"
      }
    },
    "config": {
      "recommendation_frequency": "daily"
    },
    "enabled": true
  },
  {
    "name": "k8s-aggressive",
    "description": "Aggressive resource profile — high CPU/memory for performance-critical workloads",
    "targets": [
      {
        "field": "/spec/containers/0/resources/requests",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "static",
          "config": {
            "value": {
              "cpu": "2",
              "memory": "4Gi"
            }
          }
        }
      },
      {
        "field": "/spec/containers/0/resources/limits",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "static",
          "config": {
            "value": {
              "cpu": "4",
              "memory": "8Gi"
            }
          }
        }
      }
    ],
    "selector": {
      "annotations": {
        "resource-broker/profile": "k8s-aggressive"
      }
    },
    "config": {
      "recommendation_frequency": "hourly"
    },
    "enabled": true
  },
  {
    "name": "spark-aggressive",
    "description": "Aggressive resource tuning for Spark workloads — patches both k8s resources and spark-submit arguments",
    "targets": [
      {
        "field": "/spec/containers/0/resources/requests",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "percentile",
          "config": {
            "percentile": 75,
            "lookback_hours": 48,
            "min": "1",
            "max": "8"
          }
        }
      },
      {
        "field": "/spec/containers/0/resources/limits",
        "patch_type": "strategic-merge",
        "strategy": {
          "type": "derived",
          "config": {
            "source_field": "spec.containers[0].resources.requests",
            "transform": "multiply(2.0)"
          }
        }
      },
      {
        "field": "/spec/containers/0/env/0",
        "patch_type": "add",
        "strategy": {
          "type": "static",
          "config": {
            "value": {
              "name": "SPARK_EXECUTOR_MEMORY",
              "value": "4g"
            }
          }
        }
      }
    ],
    "selector": {
      "annotations": {
        "resource-broker/profile": "spark-aggressive"
      },
      "label_selector": "app.kubernetes.io/component=spark"
    },
    "config": {
      "recommendation_frequency": "real-time"
    },
    "enabled": true
  }
]
